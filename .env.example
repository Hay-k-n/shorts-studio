# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND  (Vercel → Settings → Environment Variables)
# Root directory: frontend
# ═══════════════════════════════════════════════════════════════════════════════

# Supabase — copy from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Backend URL — set to your Railway API service public URL (no trailing slash)
# Server-side only (no NEXT_PUBLIC_ prefix needed — proxy routes use this).
BACKEND_URL=https://your-backend.railway.app

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND  (Railway → API service → Variables)
# Root directory: backend | Config file: railway.toml
# ═══════════════════════════════════════════════════════════════════════════════

PORT=4000

# Supabase service role key (never expose to browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of allowed CORS origins
# Add your Vercel URL here after first deploy
FRONTEND_URL=http://localhost:3000,https://your-frontend.vercel.app

# Set to "true" to also allow all *.vercel.app preview deployment URLs
VERCEL_PREVIEW_ALLOWED=false

# Redis — Railway auto-sets REDIS_URL when you add the Redis service
REDIS_URL=redis://localhost:6379

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND WORKER  (Railway → Worker service → Variables)
# Root directory: backend | Config file: railway.worker.toml
# Share all the same env vars as the API service (Railway "Shared Variables").
# ═══════════════════════════════════════════════════════════════════════════════

# (same variables as API service above — use Railway shared variable references)

# ═══════════════════════════════════════════════════════════════════════════════
# AI / VIDEO APIs  (stored per-workspace in DB; these are development fallbacks)
# Add to both Railway services.
# ═══════════════════════════════════════════════════════════════════════════════

ANTHROPIC_API_KEY=sk-ant-...
HEYGEN_API_KEY=...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...
TWELVELABS_API_KEY=...
