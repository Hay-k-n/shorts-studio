# ─── Dependencies ────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Build outputs ────────────────────────────────────────────────────────────
dist/
build/
.next/
out/

# ─── Environment files (NEVER commit real secrets) ────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production
# Keep .env.example — it documents required variables without real values
!.env.example

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Temp / cache ─────────────────────────────────────────────────────────────
.cache/
.turbo/
.vercel/
*.tsbuildinfo
next-env.d.ts

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Supabase local dev ────────────────────────────────────────────────────────
supabase/.branches
supabase/.temp

# ─── Temp video files (written by worker at runtime) ─────────────────────────
/tmp/
backend/tmp/
